{
  "name": "flowpilot-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered workflow automation platform for businesses.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start": "node --env-file-if-exists=.env backend/server.js",
    "dev": "node --env-file-if-exists=.env backend/server.js",
    "dev:api": "node --env-file-if-exists=.env backend/server.js",
    "dev:web": "npm run dev --workspace apps/web",
    "build:web": "npm run build --workspace apps/web",
    "lint:web": "npm run lint --workspace apps/web",
    "test": "node backend/test.js",
    "migrate": "node --env-file-if-exists=.env backend/migrate.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bullmq": "^5.80.2",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.9"
  }
}
